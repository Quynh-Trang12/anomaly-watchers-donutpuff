# Backend runtime configuration
ANOMALY_WATCHERS_TOKEN_SECRET=change-this-dev-secret
APP_FRONTEND_URL=http://localhost:8080

# FastAPI-Mail provider label (for logs/response metadata)
MAIL_PROVIDER=fastapi_mail

# Sender identity
MAIL_FROM=alerts@anomalywatchers.dev
MAIL_FROM_NAME=AnomalyWatchers

# SMTP server settings used by FastAPI-Mail
# ------------------------------------------------------------------
# Option A: Mailhog (local)
# MAIL_SERVER=127.0.0.1
# MAIL_PORT=1025
# MAIL_USE_CREDENTIALS=false
# MAIL_STARTTLS=false
# MAIL_SSL_TLS=false
# MAIL_VALIDATE_CERTS=false
# MAIL_USERNAME=
# MAIL_PASSWORD=
#
# Option B: Mailtrap (sandbox)
# MAIL_SERVER=sandbox.smtp.mailtrap.io
# MAIL_PORT=2525
# MAIL_USE_CREDENTIALS=true
# MAIL_STARTTLS=true
# MAIL_SSL_TLS=false
# MAIL_VALIDATE_CERTS=false
# MAIL_USERNAME=your-mailtrap-username
# MAIL_PASSWORD=your-mailtrap-password
# ------------------------------------------------------------------

# Default values below are localhost Mailhog-friendly.
MAIL_SERVER=127.0.0.1
MAIL_PORT=1025
MAIL_USE_CREDENTIALS=false
MAIL_STARTTLS=false
MAIL_SSL_TLS=false
MAIL_VALIDATE_CERTS=false
MAIL_USERNAME=
MAIL_PASSWORD=

# Optional comma-separated fallback admin emails for review queue alerts.
# Useful when no admin account exists in users.json yet.
ADMIN_REVIEW_EMAILS=
